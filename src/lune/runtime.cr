require "file_utils"

module Lune
  module Runtime
    LUNEJS_DIR = "frontend/lunejs"

    def self.generate_runtime_js : String
      <<-JS
      // Generated by Lune — do not edit by hand.

      export const __lune = {
        call(name, ...args) {
          return window[name](...args);
        },
      };

      // Event bus — wraps the globals set up by Lune's wv.init script.
      export function on(name, cb)   { window.__lune_on(name, cb, -1); }
      export function once(name, cb) { window.__lune_on(name, cb,  1); }
      export function off(name, cb)  { window.__lune_off(name, cb); }
      JS
    end

    def self.generate_app_js(binding_names : Array(String)) : String
      stubs = String.build do |sb|
        binding_names.each do |name|
          safe = name.gsub(".", "__").gsub(/[^A-Za-z0-9_]/, "_")
          sb << "export function #{safe}(...args) { return __lune.call(#{name.inspect}, ...args); }\n"
        end
      end

      <<-JS
      // Generated by Lune — do not edit by hand.
      // #{binding_names.size} binding(s): #{binding_names.join(", ")}

      import { __lune } from "../runtime/runtime.js";

      // Named stubs — import these directly for IDE autocompletion:
      #{stubs}

      // Dynamic api proxy — routes api.foo(...) and api.ns.bar(...) to the
      // webview-injected globals without requiring binding names at build time.
      function __makeApi(prefix) {
        return new Proxy(function () {}, {
          apply(_, __, args) {
            return __lune.call(prefix, ...args);
          },
          get(_, prop) {
            if (typeof prop !== "string") return undefined;
            const name = prefix ? prefix + "." + prop : prop;
            return __makeApi(name);
          },
        });
      }

      export const api = __makeApi("");
      export default api;
      JS
    end

    private def self.write_if_changed(path : String, content : String) : Bool
      return false if File.exists?(path) && File.read(path) == content
      File.write(path, content)
      true
    end

    def self.write_js(binding_names : Array(String), lunejs_dir : String = LUNEJS_DIR)
      app_path = File.join(lunejs_dir, "app", "App.js")
      runtime_path = File.join(lunejs_dir, "runtime", "runtime.js")

      FileUtils.mkdir_p(File.dirname(app_path))
      FileUtils.mkdir_p(File.dirname(runtime_path))

      runtime_changed = write_if_changed(runtime_path, generate_runtime_js)
      app_changed = write_if_changed(app_path, generate_app_js(binding_names))

      if runtime_changed || app_changed
        Lune.logger.info { "Lune JS written → #{app_path}, #{runtime_path}" }
      end
    end
  end
end
